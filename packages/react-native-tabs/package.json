    "@shopify/flash-list": "^2.1.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.0",
    "@types/react-native": "0.73.0",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "commitlint": "^20.1.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.37.0",
