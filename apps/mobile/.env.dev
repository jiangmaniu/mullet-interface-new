# ========== Gradle JVM 内存配置（团队默认） ==========
# 适用于 16-32GB 内存的开发机器
# 如需个性化配置，请在 .env.dev.local 中覆盖（不会提交到 git）
GRADLE_JVM_MAX_HEAP=4096m
GRADLE_JVM_MAX_METASPACE=1024m
# GRADLE_JVM_EXTRA_ARGS=  # 可选的额外 JVM 参数

# ========== iOS 构建优化配置（团队默认） ==========
# Xcode 并行编译线程数（适用于 8 核及以上 CPU）
XCODE_PARALLEL_BUILD_THREADS=4
