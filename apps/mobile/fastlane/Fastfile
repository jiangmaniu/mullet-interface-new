default_platform(:ios)

before_all do
  ensure_env_vars(
    env_vars: ["APP_ENV", "TEAM_ID"]
  )
  UI.message("🏗️  当前构建环境: #{ENV['APP_ENV']}")

  # 配置 App Store Connect API Key（替代 Apple ID 密码认证）
  if ENV["APP_STORE_CONNECT_KEY_ID"] && ENV["APP_STORE_CONNECT_ISSUER_ID"]
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_filepath: "./fastlane/AuthKey_#{ENV['APP_STORE_CONNECT_KEY_ID']}.p8",
      duration: 1200,
      in_house: false
    )
    UI.success("✅ 已配置 App Store Connect API Key 认证")
  else
    UI.message("⚠️  未配置 API Key，将使用 Apple ID 密码认证")
  end
end

# ============================================
# iOS Lanes
# ============================================
platform :ios do

  desc "Build iOS and upload to TestFlight"
  lane :beta do
    ios_build(export_method: "app-store")

    begin
      upload_to_testflight(
        skip_waiting_for_build_processing: true
      )
    rescue => e
      UI.error("TestFlight 上传失败: #{e.message}")
      UI.important("IPA 已构建成功: #{lane_context[SharedValues::IPA_OUTPUT_PATH]}")
      UI.important("请使用 Transporter App 或 xcrun altool 手动上传")
      raise e
    end
  end

  desc "Build iOS IPA only (no upload)"
  lane :build_only do
    ios_build(export_method: "development")
  end

  desc "Build iOS IPA with AdHoc signing for testing distribution"
  lane :adhoc do
    ios_build(export_method: "ad-hoc")
  end

  desc "Build iOS IPA with app-store signing (no upload)"
  lane :build_release do
    ios_build(export_method: "app-store")
  end

  private_lane :ios_build do |options|
    export_method = options[:export_method] || "development"
    bundle_id = ENV["IOS_BUNDLE_ID"]

    workspace = File.expand_path(Dir.glob("../ios/*.xcworkspace").first)
    xcodeproj = File.expand_path(Dir.glob("../ios/*.xcodeproj").first)

    UI.user_error!("ios/ 目录下未找到 .xcworkspace 文件") unless workspace
    UI.user_error!("ios/ 目录下未找到 .xcodeproj 文件") unless xcodeproj

    scheme = File.basename(xcodeproj, ".xcodeproj")

    match_type = case export_method
                 when "app-store" then "appstore"
                 when "ad-hoc" then "adhoc"
                 else "development"
                 end

    UI.message("工作空间: #{workspace}")
    UI.message("Scheme: #{scheme}")
    UI.message("Bundle ID: #{bundle_id}")
    UI.message("导出方式: #{export_method}")
    UI.message("签名类型: #{match_type}")

    # CI 环境只读（防止意外创建证书），本地环境允许下载
    # 如果 match 仓库已有证书，会自动下载；如果没有，会报错提示管理员创建
    is_ci = ENV["CI"] == "true"

    # 是否强制重新生成证书（用于证书过期、添加新设备、修改 Capabilities 等场景）
    force_regenerate = ENV["FORCE_REGENERATE_CERTIFICATES"] == "true"

    match_options = {
      type: match_type,
      app_identifier: bundle_id,
      readonly: is_ci && !force_regenerate,  # 强制重新生成时允许写入
      force: force_regenerate,               # 强制重新生成所有证书和 Profile
      force_for_new_devices: force_regenerate && match_type == "adhoc"  # Ad Hoc 自动添加新设备
    }

    begin
      match(match_options)
    rescue => e
      if e.message.include?("No matching provisioning profiles found")
        UI.error("❌ Match 仓库中缺少 #{match_type} 类型的 provisioning profile")
        UI.important("请联系管理员运行以下命令生成：")
        UI.command("bundle exec fastlane match #{match_type} --env #{ENV['APP_ENV']}")
        raise e
      else
        raise e
      end
    end

    profile_name = ENV["sigh_#{bundle_id}_#{match_type}_profile-name"]

    code_sign_identity = case match_type
                         when "appstore", "adhoc" then "Apple Distribution"
                         else "Apple Development"
                         end

    update_code_signing_settings(
      use_automatic_signing: false,
      path: xcodeproj,
      team_id: ENV["TEAM_ID"],
      bundle_identifier: bundle_id,
      profile_name: profile_name,
      code_sign_identity: code_sign_identity
    )

    if ENV["VERSION_NAME"]
      increment_version_number(
        version_number: ENV["VERSION_NAME"],
        xcodeproj: xcodeproj
      )
    end

    if ENV["VERSION_CODE"]
      increment_build_number(
        build_number: ENV["VERSION_CODE"],
        xcodeproj: xcodeproj
      )
    end

    build_app(
      workspace: workspace,
      scheme: scheme,
      export_method: export_method,
      output_directory: File.expand_path("../build"),
      output_name: "Mullet-#{ENV['APP_ENV']}.ipa",
      clean: true,
      export_options: {
        signingStyle: "manual",
        teamID: ENV["TEAM_ID"],
        provisioningProfiles: {
          bundle_id => profile_name
        }
      }
    )
  end
end

# ============================================
# Android Lanes
# ============================================
platform :android do

  desc "Build Android Release APK"
  lane :apk do
    properties = {}
    properties["versionName"] = ENV["VERSION_NAME"] if ENV["VERSION_NAME"]
    properties["versionCode"] = ENV["VERSION_CODE"] if ENV["VERSION_CODE"]

    gradle(
      project_dir: File.expand_path("../android"),
      task: "assemble",
      build_type: "Release",
      properties: properties
    )

    # 复制 APK 到 build 目录
    build_dir = File.expand_path("../build")
    apk_path = lane_context[SharedValues::GRADLE_APK_OUTPUT_PATH]
    if apk_path && File.exist?(apk_path)
      sh("mkdir -p '#{build_dir}'")
      sh("cp '#{apk_path}' '#{build_dir}/Mullet-#{ENV['APP_ENV']}.apk'")
      UI.success("APK 输出: #{build_dir}/Mullet-#{ENV['APP_ENV']}.apk")
    end
  end

  desc "Build Android AAB (for Play Store)"
  lane :aab do
    properties = {}
    properties["versionName"] = ENV["VERSION_NAME"] if ENV["VERSION_NAME"]
    properties["versionCode"] = ENV["VERSION_CODE"] if ENV["VERSION_CODE"]

    gradle(
      project_dir: File.expand_path("../android"),
      task: "bundle",
      build_type: "Release",
      properties: properties
    )
  end
end
